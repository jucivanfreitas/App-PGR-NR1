    "next": "^16.2.7",
    "pg": "^8.10.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.15.0",
