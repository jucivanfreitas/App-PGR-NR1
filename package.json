    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.2.7",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
